{
  "manifest_version": 3,
  "name": "Prime Video Subtitle Probe",
  "version": "0.2.0",
  "description": "Logs Prime Video subtitle text changes so we can verify DOM access.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": [
        "*://*.primevideo.com/*",
        "*://*.amazon.com/*",
        "*://*.amazon.in/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "host_permissions": [
    "http://127.0.0.1:5000/*",
    "http://localhost:5000/*",
    "http://127.0.0.1:11434/*",
    "http://localhost:11434/*"
  ]
}
