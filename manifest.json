{
  "manifest_version": 3,
  "name": "Prime Video Subtitle Probe",
  "version": "0.1.0",
  "description": "Logs Prime Video subtitle text changes so we can verify DOM access.",
  "content_scripts": [
    {
      "matches": [
        "*://*.primevideo.com/*",
        "*://*.amazon.com/*",
        "*://*.amazon.in/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
